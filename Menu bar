<style>
:root {
  --red: #f03030;
  --red-dark: #c01e1e;
  --black: #080808;
  --off-white: #f2ede6;
  --muted: #7a7268;
  --border: rgba(255,255,255,0.08);
  --gray-bg: #161616;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--black);
  color: var(--off-white);
  font-family: 'DM Sans', sans-serif;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ── LOGO SVG inline ── */
.logo-svg {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
  border-radius: 50%;
  object-fit: cover;
}

/* ══════════════════════════════
   NAV & DESKTOP MENU
══════════════════════════════ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  background: rgba(8,8,8,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

@media (min-width: 1024px) {
  nav {
    padding: 16px 48px;
    gap: 48px;
  }
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: 16px;
  text-decoration: none;
  flex-shrink: 0;
}

.nav-brand-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  color: #fff;
  letter-spacing: 1px;
  line-height: 1.1;
}

@media (min-width: 1024px) {
  .nav-brand-text {
    font-size: 26px;
  }
}

.nav-brand-text span { color: var(--red); }

.nav-tagline {
  font-family: 'Tiro Devanagari Marathi', serif;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.5px;
  display: block;
  margin-top: 3px;
}

@media (min-width: 1024px) {
  .nav-tagline {
    font-size: 11px;
  }
}

/* Desktop Navigation Links */
.desktop-nav-links {
  display: none;
}

@media (min-width: 1024px) {
  .desktop-nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }
  .desktop-nav-links a {
    color: var(--off-white);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .desktop-nav-links a:hover {
    color: var(--red);
  }
}

.nav-right-section {
  display: flex;
  align-items: center;
  gap: 16px;
}

.nav-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--red);
  color: #fff;
  text-decoration: none;
  font-size: 13px;
  font-weight: 700;
  padding: 10px 18px;
  border-radius: 2px;
  transition: background 0.2s;
  flex-shrink: 0;
}

@media (min-width: 1024px) {
  .nav-cta {
    font-size: 14px;
    padding: 12px 24px;
    gap: 10px;
  }
}

.nav-cta:hover { background: var(--red-dark); }
.nav-cta svg { width: 16px; height: 16px; }

/* Hamburger Toggle Button */
.menu-toggle-btn {
  background: transparent;
  border: none;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 4px;
  z-index: 110;
}

@media (min-width: 1024px) {
  .menu-toggle-btn {
    display: none;
  }
}

.menu-toggle-btn span {
  display: block;
  width: 24px;
  height: 2px;
  background-color: var(--off-white);
  transition: all 0.3s ease;
}

/* ══════════════════════════════
   MOBILE NAV SLIDE-IN OVERLAY
══════════════════════════════ */
.mobile-nav-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 104;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.mobile-nav-side-panel {
  position: fixed;
  top: 0;
  right: -300px;
  width: 280px;
  height: 100%;
  background: #ffffff; /* स्क्रीनशॉट सारखा पांढरा प्रीमियम लुक */
  z-index: 105;
  box-shadow: -4px 0 20px rgba(0,0,0,0.3);
  transition: right 0.3s ease;
  display: flex;
  flex-direction: column;
  padding-top: 60px;
}

/* Open States for Mobile Drawer */
body.mobile-menu-active .mobile-nav-overlay {
  opacity: 1;
  pointer-events: auto;
}

body.mobile-menu-active .mobile-nav-side-panel {
  right: 0;
}

/* Close Button in Sidebar */
.close-sidebar-btn {
  position: absolute;
  top: 16px;
  right: 16px;
  background: #0f2b5c;
  border: none;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.close-sidebar-btn svg {
  width: 16px;
  height: 16px;
  stroke: #ffffff;
}

/* Mobile Link Items Style */
.mobile-menu-list {
  list-style: none;
  display: flex;
  flex-direction: column;
}

.mobile-menu-item {
  border-bottom: 1px solid #eef2f5;
}

.mobile-menu-link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  color: #55606e;
  text-decoration: none;
  font-size: 16px;
  font-weight: 700;
  transition: background 0.2s;
}

.mobile-menu-link-row.active-link {
  color: #0f2b5c;
}

/* Dropdown Arrow Icons */
.mobile-dropdown-arrow-box {
  background: #f4f7f9;
  width: 36px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
}

.mobile-dropdown-arrow-box svg {
  width: 14px;
  height: 14px;
  fill: #0f2b5c;
}

/* ══════════════════════════════
   HERO & OTHER SECTIONS
══════════════════════════════ */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100px 24px 40px;
  position: relative;
  overflow: hidden;
}

@media (min-width: 768px) {
  .hero { padding: 120px 40px 60px; }
}

@media (min-width: 1024px) {
  .hero { padding: 140px 60px 80px; }
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 5% 50%, rgba(240,48,48,0.14) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 95% 10%, rgba(240,48,48,0.07) 0%, transparent 55%);
  pointer-events: none;
}

.hero-bg-text {
  position: absolute;
  right: -20px;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(120px, 22vw, 280px);
  color: rgba(240,48,48,0.04);
  line-height: 1;
  pointer-events: none;
  user-select: none;
  white-space: nowrap;
}

.hero-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 20px;
  max-width: 720px;
}

@media (min-width: 1024px) {
  .hero-inner { max-width: 900px; padding: 50px; }
}

.hero-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(24px, 7vw, 72px);
  line-height: 1.1;
  color: #fff;
  font-weight: 900;
  margin-bottom: 16px;
  letter-spacing: -1px;
}

.claim-rejected { color: #f03030; display: block; }
.we-fight { color: #22c55e; display: block; }

.hero-sub {
  font-family: 'Tiro Devanagari Marathi', serif;
  font-size: clamp(16px, 2.8vw, 24px);
  color: #b0a898;
  max-width: 580px;
  line-height: 1.7;
  margin-bottom: 28px;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-bottom: 32px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--red);
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  font-size: 15px;
  padding: 16px 28px;
  border-radius: 2px;
  transition: background 0.2s, transform 0.15s;
}
.btn-primary:hover { background: var(--red-dark); transform: translateY(-2px); }
.btn-primary svg { width: 20px; height: 20px; }

.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  border: 1px solid rgba(255,255,255,0.2);
  color: var(--off-white);
  text-decoration: none;
  font-size: 15px;
  font-weight: 500;
  padding: 16px 28px;
  border-radius: 2px;
}

.hero-stats {
  display: flex;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: 3px;
  overflow: hidden;
  max-width: 560px;
}
.h-stat {
  flex: 1;
  padding: 20px 16px;
  border-right: 1px solid var(--border);
  text-align: center;
}
.h-stat:last-child { border-right: none; }
.h-stat-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(28px, 5vw, 42px);
  color: var(--red);
  line-height: 1;
  display: block;
}
.h-stat-l {
  font-family: 'Tiro Devanagari Marathi', serif;
  font-size: 11px;
  color: var(--muted);
  margin-top: 4px;
  display: block;
}

/* ══════════════════════════════
   PROBLEM SECTION
══════════════════════════════ */
.section { padding: 80px 24px; position: relative; }
.section-inner { max-width: 960px; margin: 0 auto; }
.section-label { font-size: 11px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: var(--red); margin-bottom: 20px; display: block; }
.section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(36px, 7vw, 64px); color: #fff; line-height: 0.95; margin-bottom: 16px; }
.section-body { font-family: 'Tiro Devanagari Marathi', serif; font-size: clamp(15px, 2vw, 18px); color: #9a9288; line-height: 1.75; max-width: 580px; }

.problem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2px; margin-top: 48px; }
.problem-card { background: rgba(255,255,255,0.025); border: 1px solid var(--border); padding: 32px 28px; }
.p-icon { font-size: 32px; margin-bottom: 16px; display: block; }
.p-title { font-weight: 700; font-size: 15px; color: #fff; margin-bottom: 10px; }
.p-text { font-family: 'Tiro Devanagari Marathi', serif; font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ══════════════════════════════
   PROCESS
══════════════════════════════ */
.process-section { background: rgba(255,255,255,0.015); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2px; margin-top: 48px; }
.step-card { padding: 36px 24px; border: 1px solid var(--border); background: var(--black); }
.step-num { font-family: 'Bebas Neue', sans-serif; font-size: 52px; color: rgba(240,48,48,0.15); line-height: 1; margin-bottom: 16px; display: block; }
.step-title { font-weight: 700; font-size: 14px; color: #fff; margin-bottom: 10px; }
.step-text { font-family: 'Tiro Devanagari Marathi', serif; font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ══════════════════════════════
   SERVICES
══════════════════════════════ */
.chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 36px; }
.chip { display: flex; align-items: center; gap: 8px; padding: 11px 18px; border: 1px solid rgba(255,255,255,0.1); border-radius: 2px; font-family: 'Tiro Devanagari Marathi', serif; font-size: 13px; color: #c0b9b0; }
.chip-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--red); flex-shrink: 0; }

/* ══════════════════════════════
   FEE
══════════════════════════════ */
.fee-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 48px; }
.fee-card { border: 1px solid var(--border); padding: 36px 32px; background: rgba(255,255,255,0.02); }
.fee-card.hl { background: rgba(240,48,48,0.06); border-color: rgba(240,48,48,0.2); }
.fee-icon { font-size: 36px; margin-bottom: 20px; display: block; }
.fee-title { font-weight: 700; font-size: 18px; color: #fff; margin-bottom: 12px; }
.fee-text { font-family: 'Tiro Devanagari Marathi', serif; font-size: 14px; color: var(--muted); line-height: 1.75; }

/* ══════════════════════════════
   SUCCESS STORIES
══════════════════════════════ */
.stories-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 48px; }
.story-card { border: 1px solid var(--border); padding: 36px 28px; background: rgba(255,255,255,0.02); position: relative; overflow: hidden; }
.story-tag { display: inline-block; background: rgba(240,48,48,0.12); color: var(--red); font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; margin-bottom: 20px; }
.story-amount { font-family: 'Bebas Neue', sans-serif; font-size: clamp(38px, 6vw, 58px); color: #fff; line-height: 1; margin-bottom: 6px; }
.story-amount sup { font-size: 0.45em; color: var(--red); vertical-align: super; }
.story-who { font-size: 11px; color: #5a5550; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 20px; }
.story-text { font-family: 'Tiro Devanagari Marathi', serif; font-size: 13.5px; color: #7a7268; line-height: 1.8; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 18px; }
.story-result { margin-top: 16px; font-size: 12px; font-weight: 700; color: #4ade80; }
.story-result::before { content: '✓  '; }

/* ══════════════════════════════
   ABOUT / NAVIN
══════════════════════════════ */
.about-section { background: rgba(255,255,255,0.015); border-top: 1px solid var(--border); }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-top: 48px; }
.about-name { font-family: 'Bebas Neue', sans-serif; font-size: clamp(42px, 7vw, 68px); color: #fff; line-height: 0.95; margin-bottom: 8px; }
.about-role { font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--red); margin-bottom: 24px; display: block; }
.about-para { font-family: 'Tiro Devanagari Marathi', serif; font-size: 14px; color: #8a8278; line-height: 1.85; margin-bottom: 16px; }
.about-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; }
.about-badge { display: flex; align-items: center; gap: 7px; padding: 8px 14px; border: 1px solid rgba(255,255,255,0.1); border-radius: 2px; font-size: 12px; color: #b0a898; }

.about-stat-list { display: flex; flex-direction: column; gap: 2px; }
.about-stat-item { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border: 1px solid var(--border); background: var(--black); }
.asi-label { font-family: 'Tiro Devanagari Marathi', serif; font-size: 13px; color: var(--muted); }
.asi-value { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--red); }

/* ══════════════════════════════
   FINAL CTA
══════════════════════════════ */
.final-cta { padding: 80px 24px; text-align: center; position: relative; overflow: hidden; }
.final-cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 70% at 50% 50%, rgba(240,48,48,0.1) 0%, transparent 70%); pointer-events: none; }
.final-cta-inner { max-width: 640px; margin: 0 auto; position: relative; z-index: 1; }
.final-cta-logo { margin: 0 auto 32px; display: flex; justify-content: center; }
.cta-h2 { font-family: 'Tiro Devanagari Marathi', serif; font-size: clamp(24px, 4vw, 36px); color: #fff; line-height: 1.4; margin-bottom: 12px; }
.cta-sub { font-family: 'Tiro Devanagari Marathi', serif; font-size: 15px; color: var(--muted); margin-bottom: 36px; line-height: 1.6; }
.cta-buttons { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-bottom: 28px; }
.cta-note { font-size: 12px; color: #5a5550; letter-spacing: 0.5px; }

/* ══════════════════════════════
   FOOTER
══════════════════════════════ */
footer { border-top: 1px solid var(--border); padding: 32px 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; max-width: 960px; margin: 0 auto; }
.footer-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.footer-brand-name { font-family: 'Bebas Neue', sans-serif; font-size: 18px; color: #fff; letter-spacing: 1px; }
.footer-brand-name span { color: var(--red); }
.footer-copy { font-size: 12px; color: #4a4540; }
.footer-links { display: flex; gap: 20px; }
.footer-links a { font-size: 12px; color: #5a5550; text-decoration: none; }

/* Floating WA Button */
.wa-float {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 200;
  width: 56px;
  height: 56px;
  background: #25d366;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(37,211,102,0.4);
  text-decoration: none;
}
.wa-float svg { width: 28px; height: 28px; }

/* RESPONSIVE LAYOUTS */
@media (max-width: 640px) {
  .hero-h1 { font-size: 58px; }
  .hero-stats { flex-direction: column; }
  .h-stat { border-right: none; border-bottom: 1px solid var(--border); }
  .h-stat:last-child { border-bottom: none; }
  .fee-grid, .stories-grid, .about-grid { grid-template-columns: 1fr; }
  .about-grid { gap: 40px; }
  nav { padding: 12px 16px; }
  .nav-cta span { display: none; }
  .hero-bg-text { display: none; }
  .hero-photo { display: block; text-align: center; margin-bottom: 24px; }
  .hero-photo img { width: 160px !important; height: 200px !important; margin: 0 auto; }
  footer { flex-direction: column; align-items: flex-start; }
}
</style>
</head>
